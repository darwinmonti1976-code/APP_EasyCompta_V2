# Secrets requis par l'Edge Function invite-member
# Déployer avec : supabase secrets set KEY=value

# Clé API Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adresse d'expédition (doit correspondre à un domaine vérifié dans Resend)
FROM_EMAIL=EasyCompta <noreply@tondomaine.com>

# Injectés automatiquement par Supabase (ne pas définir manuellement) :
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
